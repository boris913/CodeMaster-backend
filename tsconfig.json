{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    
    // Options strictes modifiées pour éviter les erreurs
    "strict": true,
    "strictNullChecks": false,        // Désactivé temporairement
    "noImplicitAny": false,           // Désactivé pour les erreurs de typage
    "strictBindCallApply": false,     // Désactivé pour Prisma
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    
    // Nouvelles options ajoutées
    "noImplicitReturns": false,
    "noImplicitThis": false,
    "alwaysStrict": false,
    "exactOptionalPropertyTypes": false,
    "noUncheckedIndexedAccess": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    
    "paths": {
      "@/*": ["src/*"]
    },
    
    // Options pour ES Modules
    "moduleResolution": "node",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    
    // Options pour la qualité du code
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    
    // Options pour la configuration lib
    "lib": ["ES2021"],
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    ".eslintrc.js"
  ]
}